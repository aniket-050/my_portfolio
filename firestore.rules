rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function validText(field, max) {
      return field is string && field.size() > 0 && field.size() <= max;
    }

    function validInquiry() {
      return request.resource.data.keys().hasOnly([
          'name',
          'email',
          'subject',
          'message',
          'status',
          'createdAt'
        ])
        && validText(request.resource.data.name, 80)
        && request.resource.data.email is string
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && request.resource.data.email.size() <= 120
        && validText(request.resource.data.subject, 160)
        && validText(request.resource.data.message, 4000)
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt is timestamp;
    }

    match /siteContent/main {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /contactInquiries/{inquiryId} {
      allow create: if validInquiry();
      allow read, update, delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
